# ASF v0.4 — Azure OpenAI Configuration
# Copy this file to .env and fill in your values
# Required for LLM mode in asf_document_analyzer.py

AZURE_OPENAI_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Without these variables, the analyzer falls back to keyword mode automatically.
# Keyword mode scores are marked Low confidence and carry no evidence citations.
